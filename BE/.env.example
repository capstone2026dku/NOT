# 데이터베이스 (SQLite — 파일 기반, 별도 설치 불필요)
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="your-jwt-secret-32chars-minimum-here"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_SECRET="your-refresh-secret-32chars-minimum"
JWT_REFRESH_EXPIRES_IN="30d"

# 토스페이먼츠
TOSS_CLIENT_KEY="test_ck_..."
TOSS_SECRET_KEY="test_sk_..."
TOSS_WEBHOOK_SECRET="your-webhook-secret"

# Firebase
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@project.iam.gserviceaccount.com"

# 서버
PORT=3000
NODE_ENV=development

# AI 서버
AI_URL=http://localhost:8000

# 단국대 학식 스크래핑
DANKOOK_MENU_URL="https://www.dankook.ac.kr/web/kor/1947_commons"
SCRAPE_CRON="0 7 * * 1-5"

# Google OAuth
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID
# 웹 애플리케이션 타입으로 생성한 클라이언트 ID (Android·iOS의 serverClientId로도 사용)
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
